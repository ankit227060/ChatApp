# Database Configuration
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/chatapp

# CORS and Client Configuration
CLIENT_BASE_URL=https://your-frontend-domain.vercel.app
SERVER_BASE_URL=https://your-backend-domain.herokuapp.com

# Security
JWT_SECRET=your-256-bit-secret-key-generate-strong-random-key

# Server Configuration
PORT=3000

# OAuth Configuration (Optional - for Google/GitHub login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Admin Configuration (Optional)
CREATOR_USER_ID=your_admin_user_id